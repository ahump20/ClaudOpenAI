name = "{{worker_name}}"
main = "src/index.ts"
compatibility_date = "2026-04-01"

[[d1_databases]]
binding = "DB"
database_name = "{{d1_database_name}}"
database_id = "{{d1_database_id}}"

[observability]
enabled = true

[[routes]]
pattern = "{{primary_domain}}/*"
zone_name = "{{zone_name}}"
custom_domain = true

[[routes]]
pattern = "{{alt_domain}}/*"
zone_name = "{{zone_name}}"
custom_domain = true
